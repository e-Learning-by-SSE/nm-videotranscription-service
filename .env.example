# =============================================================================
# Selflearn Transkriptions-Backend - Umgebungsvariablen
# =============================================================================
# Kopieren Sie diese Datei nach .env und passen Sie die Werte an:
#   cp .env.example .env
# =============================================================================

# =============================================================================
# Pflicht-Konfiguration (müssen gesetzt werden!)
# =============================================================================

# JWT Secret Key für Authentifizierung (muss identisch zum Selflearn-Backend sein)
AUTH_SECRET_KEY=your-secret-key-here-change-this

# Endpoint zum Speichern der Transkription im Selflearn-Backend
SAVE_SUBTITLE_ENDPOINT=http://localhost:4200/api/subtitle/save_subtitle

# Whisper-Modell: tiny, base, small, medium, large
# Größere Modelle = bessere Qualität, aber langsamer und mehr VRAM
WHISPER_MODEL=small

# =============================================================================
# Server-Konfiguration (optional)
# =============================================================================

# Bind-Adresse des Servers
HOST=0.0.0.0

# Port des Servers
PORT=5000

# Debug-Modus (true/false) - NICHT in Produktion aktivieren!
DEBUG=false

# Optional CORS allowed origins (comma-separated, e.g. "http://localhost:4200,http://example.com")
CORS_ALLOWED_ORIGINS=*

# =============================================================================
# Download-Konfiguration (optional)
# =============================================================================

# Chunk-Größe in Bytes beim Video-Download
DOWNLOAD_CHUNK_SIZE=8192

# Timeout in Sekunden für HTTP-Requests
DOWNLOAD_TIMEOUT=30

# =============================================================================
# Logging (optional)
# =============================================================================

# Log-Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log-Format (Python logging format)
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
